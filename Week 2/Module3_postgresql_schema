SELECT COUNT(*) AS total_departments FROM departments;
SELECT COUNT(*) AS total_students FROM students;
SELECT COUNT(*) AS total_courses FROM courses;
SELECT COUNT(*) AS total_enrollments FROM enrollments;
SELECT COUNT(*) AS total_professors FROM professors;

-- INNER JOIN
SELECT
    st.first_name,
    st.last_name,
    dp.dept_name
FROM students st
JOIN departments dp
ON st.department_id = dp.department_id;

-- Student with Course
SELECT
    st.first_name,
    st.last_name,
    cr.course_title
FROM enrollments en
JOIN students st
ON en.student_id = st.student_id
JOIN courses cr
ON en.course_id = cr.course_id;

-- Students without Enrollment
SELECT
    st.first_name,
    st.last_name
FROM students st
LEFT JOIN enrollments en
ON st.student_id = en.student_id
WHERE en.student_id IS NULL;

-- Course-wise Student Count
SELECT
    cr.course_title,
    COUNT(en.student_id) AS enrolled_students
FROM courses cr
LEFT JOIN enrollments en
ON cr.course_id = en.course_id
GROUP BY cr.course_title;

-- Department & Professors
SELECT
    dp.dept_name,
    pr.professor_name,
    pr.salary
FROM departments dp
LEFT JOIN professors pr
ON dp.department_id = pr.department_id;

