class Car:
    def drive(self):
        print("Driving a Car")

class Bike:
    def drive(self):
        print("Riding a Bike")

class VehicleFactory:
    def create_vehicle(self, choice):
        vehicles = {
            "car": Car,
            "bike": Bike
        }
        if choice in vehicles:
            return vehicles[choice]()
        return None

factory = VehicleFactory()
vehicle = factory.create_vehicle("car")

if vehicle:
    vehicle.drive()
